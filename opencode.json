{
  "$schema": "https://opencode.ai/schema.json",
  "model": "anthropic/claude-3-opus",
  "small_model": "anthropic/claude-3-haiku",
  "default_agent": "tachikoma",
  "experimental": {
    "batch_tool": true
  },
  "skills": {
    "paths": ["src/skills"]
  },
  "agent": {
    "tachikoma": {
      "description": "Research-focused agent with caveman voice, graph memory, PAUL methodology, skill tracking, and verification loops.",
      "mode": "primary",
      "prompt": "src/agents/tachikoma.md",
      "permission": {
        "terminal": "allow",
        "read": "allow",
        "write": "allow",
        "web": "allow",
        "todo": "allow",
        "skills": "allow"
      }
    }
  },
  "mcp": {
    "caveman-compress": {
      "type": "local",
      "command": ["tachikoma-mcp-python"],
      "enabled": true
    }
  },
  "plugin": [
    "src/plugin/tachikoma.ts",
    "src/plugin/tachikoma/opensage/graph-memory.ts",
    "src/plugin/tachikoma/opensage/opensage-agents.ts",
    "src/plugin/tachikoma/graph-routing/plugin-integration.ts",
    "src/plugin/tachikoma/opensage/dynamic-tools.ts"
  ]
}
